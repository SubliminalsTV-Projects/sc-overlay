{
  "name": "sc-log-watcher",
  "version": "0.1.0",
  "description": "Watches the Star Citizen game.log and emits structured events.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "loadout": "tsx src/erkul-dump.ts",
    "overlay": "tsx src/overlay-server.ts",
    "agent": "tsx src/agent.ts",
    "missions-dump": "tsx src/missions-dump.ts",
    "missions-replay": "tsx src/missions-replay.ts",
    "standalone": "tsx src/standalone.ts",
    "package": "node tools/package.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
